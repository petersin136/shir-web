# ⚠️ 이 파일은 "예시"입니다. Next.js는 이 파일을 읽지 않습니다.
#
# 로컬 개발: 아래 내용을 복사해 프로젝트 루트에 .env.local 파일을 만드세요.
#   cp .env.example .env.local
# 그다음 .env.local 안의 값을 Supabase Dashboard → Project Settings → API 에서 채우세요.
#
# Vercel 배포: Project → Settings → Environment Variables 에 동일한 이름으로 등록하세요.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 관리자 목록 삭제 등 (RLS 우회) — service_role secret
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
